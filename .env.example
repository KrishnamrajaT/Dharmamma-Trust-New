# Frontend environment
# Razorpay public key (Key ID)
REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# Backend API base URL for local/dev or separate deployments
# Leave empty if frontend and backend are served from same domain
REACT_APP_API_BASE_URL=https://dharmamma-trust-new-nqra.vercel.app

# Website URL registered in Razorpay settings (must match the domain where checkout opens)
REACT_APP_RAZORPAY_REGISTERED_WEBSITE_URL=https://dharmamma-trust-new-nqra.vercel.app
